APP_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
BUS_LOCATION_TTL_SECONDS=30
STREAM_MAXLEN=500

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=transit_app
DB_PASSWORD=changeme
DB_NAME=transit_db
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Geofence
GEOFENCE_ALERT_COOLDOWN_SECONDS=60

# Crowdsource
CROWDSOURCE_GRACE_PERIOD_SECONDS=30
CROWDSOURCE_MIN_SPEED_KMH=15.0
CROWDSOURCE_MAX_SPEED_KMH=80.0
CROWDSOURCE_CLUSTER_RADIUS_M=20.0
CROWDSOURCE_MIN_QUORUM=2
CROWDSOURCE_PING_TTL_SECONDS=15
CROWDSOURCE_LOCATION_TTL_SECONDS=45
CROWDSOURCE_CHECK_INTERVAL_SECONDS=10
CROWDSOURCE_ACTIVE_FLAG_TTL_SECONDS=120

# ETA Model
